# .env.example
#
# EduBoost SA — Environment Variable Reference
#
# INSTRUCTIONS:
#   1. Copy this file to .env for local development:
#        cp .env.example .env
#   2. Fill in all required values (marked REQUIRED).
#   3. NEVER commit .env to version control.
#      .env is already in .gitignore — keep it that way.
#   4. For production, supply these via your deployment secrets manager
#      (GitHub Secrets + SSH env injection for VPS, or AWS Secrets Manager for cloud).
#
# See CONTRIBUTING.md → "Environment Setup" for full instructions.

# ──────────────────────────────────────────────────────────────────────────────
# POSTGRESQL
# ──────────────────────────────────────────────────────────────────────────────

# Database name (default safe for local dev)
POSTGRES_DB=eduboost

# Database user (default safe for local dev)
POSTGRES_USER=eduboost_user

# REQUIRED: Change this for staging/production.
# Min 32 chars, randomly generated: openssl rand -base64 32
POSTGRES_PASSWORD=devpassword_change_me_in_production

# ──────────────────────────────────────────────────────────────────────────────
# REDIS
# ──────────────────────────────────────────────────────────────────────────────

# Leave empty for local dev (no Redis auth).
# REQUIRED in production: openssl rand -base64 24
REDIS_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# RABBITMQ (Fourth Estate Audit Trail)
# ──────────────────────────────────────────────────────────────────────────────

# REQUIRED for durable audit trail
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ──────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION & ENCRYPTION
# ──────────────────────────────────────────────────────────────────────────────

# REQUIRED: JWT signing secret. Min 32 chars.
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_a_strong_random_secret_here

# REQUIRED: Symmetric encryption key for pgcrypto (email encryption).
# Must be exactly 32 bytes (256-bit AES).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=CHANGE_ME_32_byte_key_here_exactly

# REQUIRED: Salt for key derivation.
# Generate: python -c "import secrets; print(secrets.token_hex(16))"
ENCRYPTION_SALT=CHANGE_ME_salt_here

# ──────────────────────────────────────────────────────────────────────────────
# LLM PROVIDERS
# ──────────────────────────────────────────────────────────────────────────────

# REQUIRED for lesson generation (primary provider)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# REQUIRED for lesson generation (secondary/failover)
# Get from: https://console.groq.com/
GROQ_API_KEY=gsk_CHANGE_ME

# Optional: for offline/fallback inference (only needed with INCLUDE_ML=true)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_CHANGE_ME

# ──────────────────────────────────────────────────────────────────────────────
# SUPABASE (Auth + Storage)
# ──────────────────────────────────────────────────────────────────────────────

# Public values — safe to expose in frontend builds
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGE_ME_anon_key

# Backend-only service role key — NEVER expose to frontend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=CHANGE_ME_service_role_key

# ──────────────────────────────────────────────────────────────────────────────
# FRONTEND
# ──────────────────────────────────────────────────────────────────────────────

# API URL as seen by the browser (not the internal Docker network name)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ──────────────────────────────────────────────────────────────────────────────
# MONITORING
# ──────────────────────────────────────────────────────────────────────────────

# Optional: Sentry error tracking DSN
# Get from: https://sentry.io/ → Projects → Your Project → Client Keys
SENTRY_DSN=

# Grafana admin password (local dev default is "admin")
# REQUIRED change in production
GRAFANA_ADMIN_PASSWORD=admin

# ──────────────────────────────────────────────────────────────────────────────
# EMAIL (Celery beat tasks: consent renewal reminders)
# ──────────────────────────────────────────────────────────────────────────────

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@eduboost.co.za
SMTP_PASSWORD=CHANGE_ME

# ──────────────────────────────────────────────────────────────────────────────
# PRODUCTION DEPLOYMENT (only needed in docker-compose.prod.yml context)
# ──────────────────────────────────────────────────────────────────────────────

# Your production domain
DOMAIN=eduboost.co.za

# Docker image registry (default: GitHub Container Registry)
REGISTRY=ghcr.io

# Image tag to deploy (set by CI/CD pipeline)
IMAGE_TAG=latest

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=https://eduboost.co.za,https://www.eduboost.co.za
