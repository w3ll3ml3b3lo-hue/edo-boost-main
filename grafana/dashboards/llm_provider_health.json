{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "description": "EduBoost SA — LLM Provider Health. Monitors Anthropic, Groq, and HuggingFace API call rates, latencies, error rates, token consumption, and failover events.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [

    {
      "id": 1,
      "title": "Anthropic — Request Rate (rpm)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqpm", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 40 }, { "color": "red", "value": 55 }] } } },
      "targets": [{ "expr": "sum(rate(eduboost_llm_requests_total{provider=\"anthropic\"}[1m])) * 60", "legendFormat": "anthropic rpm" }]
    },

    {
      "id": 2,
      "title": "Groq — Request Rate (rpm)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqpm", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 140 }] } } },
      "targets": [{ "expr": "sum(rate(eduboost_llm_requests_total{provider=\"groq\"}[1m])) * 60", "legendFormat": "groq rpm" }]
    },

    {
      "id": 3,
      "title": "HuggingFace — Request Rate (rpm)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqpm" } },
      "targets": [{ "expr": "sum(rate(eduboost_llm_requests_total{provider=\"huggingface\"}[1m])) * 60", "legendFormat": "hf rpm" }]
    },

    {
      "id": 4,
      "title": "LLM Error Rate by Provider",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] }
        }
      },
      "targets": [
        { "expr": "sum(rate(eduboost_llm_errors_total{provider=\"anthropic\"}[5m])) / sum(rate(eduboost_llm_requests_total{provider=\"anthropic\"}[5m]))", "legendFormat": "Anthropic error %" },
        { "expr": "sum(rate(eduboost_llm_errors_total{provider=\"groq\"}[5m])) / sum(rate(eduboost_llm_requests_total{provider=\"groq\"}[5m]))", "legendFormat": "Groq error %" }
      ]
    },

    {
      "id": 5,
      "title": "Failover Events (Primary → Fallback)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        }
      },
      "targets": [{ "expr": "sum(increase(eduboost_llm_failover_total[1h]))", "legendFormat": "Failovers/hour" }]
    },

    {
      "id": 10,
      "title": "LLM Request Latency by Provider (p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max", "mean"] } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(eduboost_llm_request_duration_seconds_bucket{provider=\"anthropic\"}[5m])) by (le))", "legendFormat": "Anthropic p95" },
        { "expr": "histogram_quantile(0.95, sum(rate(eduboost_llm_request_duration_seconds_bucket{provider=\"groq\"}[5m])) by (le))", "legendFormat": "Groq p95" },
        { "expr": "histogram_quantile(0.95, sum(rate(eduboost_llm_request_duration_seconds_bucket{provider=\"huggingface\"}[5m])) by (le))", "legendFormat": "HuggingFace p95" },
        { "expr": "histogram_quantile(0.50, sum(rate(eduboost_llm_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "All providers p50" }
      ]
    },

    {
      "id": 11,
      "title": "Token Consumption by Provider (per minute)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "expr": "sum(rate(eduboost_llm_tokens_total{provider=\"anthropic\",type=\"input\"}[1m])) * 60", "legendFormat": "Anthropic input" },
        { "expr": "sum(rate(eduboost_llm_tokens_total{provider=\"anthropic\",type=\"output\"}[1m])) * 60", "legendFormat": "Anthropic output" },
        { "expr": "sum(rate(eduboost_llm_tokens_total{provider=\"groq\",type=\"input\"}[1m])) * 60", "legendFormat": "Groq input" },
        { "expr": "sum(rate(eduboost_llm_tokens_total{provider=\"groq\",type=\"output\"}[1m])) * 60", "legendFormat": "Groq output" }
      ]
    },

    {
      "id": 12,
      "title": "Rate Limit Hits by Provider",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "sum(increase(eduboost_llm_rate_limit_hits_total{provider=\"anthropic\"}[1m]))", "legendFormat": "Anthropic 429s" },
        { "expr": "sum(increase(eduboost_llm_rate_limit_hits_total{provider=\"groq\"}[1m]))", "legendFormat": "Groq 429s" }
      ]
    },

    {
      "id": 13,
      "title": "Content Safety Blocks (LLM Firewall)",
      "description": "Responses blocked by the judiciary.py content safety layer before reaching learners",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "targets": [
        { "expr": "sum(increase(eduboost_llm_content_blocked_total[1h]))", "legendFormat": "Content blocks/hour" },
        { "expr": "sum(increase(eduboost_llm_pii_detected_total[1h]))", "legendFormat": "PII detected in response/hour" }
      ]
    },

    {
      "id": 14,
      "title": "LLM Provider Availability (last 5m)",
      "type": "table",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Availability" }, "properties": [{ "id": "unit", "value": "percentunit" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 }] } }, { "id": "custom.displayMode", "value": "color-background" }] }
        ]
      },
      "transformations": [{ "id": "merge", "options": {} }],
      "targets": [
        { "expr": "1 - (sum(rate(eduboost_llm_errors_total[5m])) by (provider) / sum(rate(eduboost_llm_requests_total[5m])) by (provider))", "legendFormat": "{{provider}}", "instant": true }
      ]
    }
  ],

  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["eduboost", "llm", "ai", "providers"],
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "Africa/Johannesburg",
  "title": "EduBoost SA — LLM Provider Health",
  "uid": "eduboost-llm-health",
  "version": 1
}
